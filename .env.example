# Local PostgreSQL (Docker Compose — host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/raahpass?schema=public"

# Optional: direct connection for Prisma CLI (migrations, db push, seed).
# Required for Neon/Supabase pooler URLs in production if auto-derivation is not used.
# Local Docker can omit this — prisma.config.ts falls back to DATABASE_URL.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/raahpass?schema=public"

# Production examples (set in Vercel dashboard — do not commit real URLs):
# Neon pooled (app runtime):  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon direct (optional):       postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# After first deploy:
# 1. Set DATABASE_URL in Vercel
# 2. Run migrations (included in vercel.json buildCommand)
# 3. Seed once: DATABASE_URL=... npm run db:seed
