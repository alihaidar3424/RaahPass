# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env (keep .env.example committed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# local reference material (images, source PDFs, design mocks — not used by app)
/reference/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma v7 generated client
/generated

# android / bubblewrap
/android.keystore
/app-release-signed.apk
/app-release-bundle.aab
/app/build/
/.gradle/
/local.properties
/manifest-checksum.txt
/store_icon.png
